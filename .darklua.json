{
  "generator": "retain_lines",
  "apply_to_files": ["src/**/*.lua", "src/**/*.luau"],
  "skip_files": ["Packages/**"],
  
  "bundle": {
    "modules_identifier": "__miastox_modules",
    "require_mode": {
      "name": "roblox",
      "indexing_style": "find_first_child"
    },
    "use_luau_configuration": true
  },
  
  "rules": [
    "remove_comments",
    "remove_spaces",
    "remove_nil_declaration",
    "compute_expression",
    "remove_unused_if_branch",
    "filter_after_early_return",
    "remove_empty_do",
    "convert_require",
    {
      "rule": "inject_global_value",
      "identifier": "MIASTOX_BUILD",
      "value": true
    }
  ]
}